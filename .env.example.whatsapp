# ============================================================
# Módulo WhatsApp — variables de entorno
# Copiar las que falten a .env.local (NO commitear .env.local).
# Detalle completo en docs/whatsapp-integration.md
# ============================================================

# --- Requeridas para procesar webhooks y worker (server-only) ---
# Supabase Dashboard → Settings → API → service_role (secreta, nunca en cliente)
SUPABASE_SERVICE_ROLE_KEY=

# --- Verificación del webhook (la inventás vos, se repite en Meta) ---
META_VERIFY_TOKEN=

# --- Cifrado de tokens de WhatsApp (generar: openssl rand -base64 32) ---
WHATSAPP_TOKEN_KEY=

# --- Worker de mensajes programados (generar: openssl rand -hex 24) ---
WHATSAPP_CRON_SECRET=

# --- App de Meta (Embedded Signup + validación de firma del webhook) ---
# Opcionales en dev: sin META_APP_SECRET el webhook no valida firma;
# sin APP_ID/CONFIG_ID la conexión oficial se reemplaza por el alta manual.
META_APP_ID=
META_APP_SECRET=
META_CONFIG_ID=

# --- Versión de la Graph API ---
WHATSAPP_API_VERSION=v21.0

# --- Dev/QA: simular envíos sin llamar a Meta (1 = simular) ---
WHATSAPP_FAKE_SEND=1

# --- Bot IA (opcional: sin key el bot queda deshabilitado) ---
ANTHROPIC_API_KEY=

# --- URL pública de la app (webhook en Meta, links) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
