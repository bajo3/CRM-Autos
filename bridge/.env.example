# ============================================================
# Bridge WhatsApp (Baileys, beta por QR) — variables de entorno
# Copiar a bridge/.env (queda gitignoreado, no se commitea).
# ============================================================

# Puerto donde escucha el bridge.
PORT=3900

# Secreto compartido: todas las rutas exigen Authorization: Bearer <BRIDGE_SECRET>.
# Generar con: openssl rand -hex 24
BRIDGE_SECRET=

# URL del webhook del CRM que recibe los mensajes entrantes (formato Meta).
CRM_WEBHOOK_URL=http://localhost:3000/api/whatsapp/webhook

# Mismo valor que META_APP_SECRET del CRM (.env.local): firma HMAC-SHA256
# de los webhooks salientes del bridge para que el CRM la valide.
META_APP_SECRET=

# Nivel de log de pino (trace|debug|info|warn|error|silent).
BRIDGE_LOG_LEVEL=info

# Proteccion anti-baneo para el modo no oficial: deja el bridge mas parecido a
# un uso humano. Por default esta activo. Usar "0" solo para QA rapido.
BRIDGE_HUMANIZER_ENABLED=1

# Separacion aleatoria entre mensajes salientes de una misma sesion.
BRIDGE_SEND_MIN_MS=6000
BRIDGE_SEND_MAX_MS=18000

# Tiempo de "escribiendo..." antes de mandar. Tambien depende del largo del texto.
BRIDGE_TYPING_MIN_MS=2500
BRIDGE_TYPING_MAX_MS=22000
BRIDGE_TYPING_CHARS_PER_SECOND=7

# Tilde azul diferido para mensajes entrantes. Apagar con 0 si no se quiere
# confirmar lectura automaticamente.
BRIDGE_READ_RECEIPTS_ENABLED=1
BRIDGE_READ_MIN_MS=2500
BRIDGE_READ_MAX_MS=12000
